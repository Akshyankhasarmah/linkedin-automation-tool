rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /preferences/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.domain is string &&
        request.resource.data.domain.size() <= 100 &&
        request.resource.data.interests is list &&
        request.resource.data.interests.size() <= 20 &&
        request.resource.data.automationActive is bool &&
        request.resource.data.startTime is string &&
        request.resource.data.startTime.size() == 5 &&
        request.resource.data.duration is int &&
        request.resource.data.duration >= 0;
    }

    match /logs/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.author is string &&
        request.resource.data.type in ['Technical', 'Hiring', 'Motivational', 'Toxic'] &&
        request.resource.data.content is string &&
        request.resource.data.content.size() <= 5000 &&
        request.resource.data.relevance is int &&
        request.resource.data.relevance >= 0 &&
        request.resource.data.relevance <= 100 &&
        request.resource.data.createdAt == request.time;
    }

    match /jobs/{jobId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.title is string &&
        request.resource.data.company is string &&
        request.resource.data.url is string;
    }
  }
}
